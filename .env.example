# Copy this file to .env and fill in the values.
# .env is gitignored — do NOT commit it.

# ── Backend ───────────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO
ANTHROPIC_API_KEY=sk-ant-...

# ── Frontend – build-time (baked into client JS bundle at pnpm build) ─────────
# URL the user's browser uses to call the API.
# In production: https://api.yourapp.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:10000

# ── Frontend – runtime (server-side only, never sent to browser) ──────────────
# Internal Docker hostname for container-to-container calls.
BACKEND_URL=http://backend:10000
