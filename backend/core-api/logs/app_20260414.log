{"asctime": "2026-04-14T17:50:18Z", "levelname": "INFO", "name": "apis.v1.routes.sessions", "message": "POST /sessions/{session_id}/turn received", "session_id": "sess_447c4b87668e", "message_length": 76, "has_face_signal": true}
